# ===== OS が作る不要ファイル =====
.DS_Store
Thumbs.db
Desktop.ini

# ===== エディタ・IDE =====
.vscode/
.idea/
*.swp
*~

# ===== Node (将来 npm を使う場合) =====
node_modules/
npm-debug.log*

# ===== Python (tools/ の検証スクリプト用) =====
__pycache__/
*.pyc
.venv/
venv/

# ===== 検証スクリプトの一時生成物 =====
# Playwright が撮るスクリーンショットなど(コミット不要)
tools/*.png

# ===== Claude Code のローカル設定(個人環境固有) =====
.claude/settings.local.json

# ===== ログ・一時ファイル =====
*.log
tmp/

# ===== 学習の成果物 (モデル・チェックポイント・TensorBoard) =====
# GitHub 公開は不要。サイズも巨大 (runs2/ は 1GB 超) なので必ず除外する。
# 新しい学習の出力先を足したら、ここにも追加すること。
runs/
runs2/
# 旧世代 (v1/v2) の学習成果物。以前は追跡していたが公開不要なので追跡解除した。
# ローカルには残してあるが、今後コミットしないこと (デモは js/policy*.js を使うので不要)
runs-v1-obs1231/
runs-v2-with-arena/
# 学習ログ・評価ログ (*.log は上でも除外済みだが明示)
*-train.log
*-eval.log

# 録画の中間ファイル (media/ai-play.webm 本体はコミットする)
media/_raw/
